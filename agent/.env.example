# Gemini API 配置
# 申请地址: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 兼容别名（shared/config.py 会自动读取，与上面填同一个 key 即可）
OPENAI_API_KEY=your_gemini_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# 使用方法：
# 1. 复制这个文件为 .env：  cp .env.example .env
# 2. 把上面两处 your_gemini_api_key_here 替换成你的真实 Gemini API Key
# 3. .env 已经在 .gitignore 里，不会被提交，放心填真实 key
